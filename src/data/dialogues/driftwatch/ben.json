{
  "ben_default": {
    "nodes": {
      "0": {
        "npc_text": "Hard work on the farm. What can I do for you?",
        "player_choices": [
          {
            "text": "We won! Pay up.",
            "next_node": "ben_pay_cheat",
            "condition": "world_flags.ben_cheat_done==true && world_flags.debt_paid_by_ben==false"
          },
          {
            "text": "Finn sent me. Pay 10 silvers.",
            "next_node": "debt_collection",
            "condition": "world_flags.finn_debt_collection_active==true && world_flags.debt_paid_by_ben==false && world_flags.ben_cheat_agreed==false"
          },
          {
            "text": "Goodbye, Ben.",
            "closes_dialogue": true,
            "condition": "world_flags.finn_debt_collection_active==true && world_flags.debt_paid_by_ben==false && world_flags.ben_cheat_agreed==false"
          },
          {
            "text": "Goodbye, Ben.",
            "closes_dialogue": true,
            "condition": "world_flags.finn_debt_collection_active==false"
          },
          {
            "text": "Goodbye, Ben.",
            "closes_dialogue": true,
            "condition": "world_flags.debt_paid_by_ben==true"
          },
          {
            "text": "Goodbye, Ben.",
            "closes_dialogue": true,
            "condition": "world_flags.ben_cheat_agreed==true && world_flags.ben_cheat_done==false"
          }
        ]
      },
      "debt_collection": {
        "npc_text": "Finn? Look, I barely have copper for seeds, let alone silver for rent. I can't pay... wait. I have a plan. The tables at the Salty Mug are busy tonight. I know a way to win, but I need a partner. Help me cheat, and I'll have the silver.",
        "player_choices": [
          {
            "text": "Fine. I'll help you cheat.",
            "next_node": "ben_cheat_agree",
            "condition": "world_flags.ben_cheat_agreed==false"
          },
          {
            "text": "Look at me, Ben. You don't want this getting ugly.",
            "next_node": "ben_intimidate",
            "condition": "presentation.intimidation>=2",
            "req_skill_level": { "skill": "coercion", "level": 2 }
          },
          {
            "text": "You've got tavern coin for drink, but not for Finn? Careful, Ben.",
            "next_node": "ben_brawl_pressure",
            "condition": "time.is_night==true"
          },
          {
            "text": "No. Pay now.",
            "closes_dialogue": true
          }
        ]
      },
      "ben_brawl_pressure": {
        "npc_text": "Don't try that with me. You think you can loom over me in front of half the Mug and walk away smiling?",
        "player_choices": [
          {
            "text": "Pay, or I drag it out of you.",
            "next_node": "ben_brawl_offer"
          },
          {
            "text": "Then prove me wrong.",
            "next_node": "ben_brawl_offer"
          },
          {
            "text": "Forget it.",
            "next_node": "0"
          }
        ]
      },
      "ben_intimidate": {
        "npc_text": "Ben glances at your gear, then at the room around you, and the drink seems to leave him all at once. \"Fine. Fine, damn you. Take it and get out before Finn decides I need a second lesson.\"",
        "player_choices": [
          {
            "text": "Smart choice.",
            "action": "collect_debt_from:npc_ben|add_xp:coercion:12",
            "closes_dialogue": true
          }
        ]
      },
      "ben_brawl_offer": {
        "npc_text": "Fine. Outside, now. If you can put me on the floor, you can take the silver and crawl back to Finn with it.",
        "player_choices": [
          {
            "text": "Stand up, then.",
            "action": "start_brawl:ben",
            "closes_dialogue": true
          },
          {
            "text": "Forget it.",
            "next_node": "0"
          }
        ]
      },
      "ben_cheat_agree": {
        "npc_text": "Good. Meet me at the Salty Mug tonight. Just follow my lead, and don't get caught.",
        "player_choices": [
          {
            "text": "See you tonight.",
            "closes_dialogue": true,
            "action": "set_flag:ben_cheat_agreed:true"
          }
        ]
      },
      "ben_pay_cheat": {
        "npc_text": "Whoa, that was close... *hic* Thanks for the help, partner! Here's your 10 silver... don't tell Elisa I'm sloshed.",
        "player_choices": [
          {
            "text": "Pleasure doing business.",
            "action": "collect_debt_from:npc_ben",
            "closes_dialogue": true
          }
        ]
      }
    }
  }
}
